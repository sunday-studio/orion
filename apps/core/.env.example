# Orion Core runtime configuration.
# Copy this file to .env in apps/core when running Core with `go run .`.

# Storage and server
ORION_DATA_DIR=data
ORION_PORT=8999
ORION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Core monitor worker diagnostics
ORION_WORKER_ID=core-monitor-worker
ORION_WORKER_HEARTBEAT_SECONDS=15
ORION_WORKER_STALE_SECONDS=60

# Data lifecycle scheduler
ORION_DATA_LIFECYCLE_SCHEDULER_SECONDS=3600

# Console authentication
# Set all three values to enable login for the web UI.
ORION_ADMIN_USERNAME=
ORION_ADMIN_PASSWORD=
ORION_JWT_SECRET=

# Login rate limiting
ORION_LOGIN_RATE_LIMIT_ATTEMPTS=5
ORION_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Webhook alerts
# Set ORION_ALERT_WEBHOOK_URL to add the webhook channel.
ORION_ALERT_WEBHOOK_URL=
ORION_ALERT_WEBHOOK_NAME=default-webhook
ORION_ALERT_WEBHOOK_ENABLED=true

# Email alerts
# Set ORION_ALERT_EMAIL_TO, ORION_ALERT_EMAIL_FROM, ORION_ALERT_SMTP_HOST,
# and ORION_ALERT_SMTP_PORT to add the email channel.
ORION_ALERT_EMAIL_TO=
ORION_ALERT_EMAIL_FROM=
ORION_ALERT_SMTP_HOST=
ORION_ALERT_SMTP_PORT=587
ORION_ALERT_SMTP_USERNAME=
ORION_ALERT_SMTP_PASSWORD=
ORION_ALERT_EMAIL_NAME=default-email
ORION_ALERT_EMAIL_ENABLED=true

# Alert behavior
ORION_ALERT_COOLDOWN_SECONDS=300
ORION_ALERT_RECOVERY_NOTIFICATIONS=true
ORION_ALERT_TLS_EXPIRY_DAYS=14
